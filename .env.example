# === AI PROVIDERS (поддержка множественных ключей: _KEY_1, _KEY_2, ...) ===
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_KEY_2=your_second_key_here

GEMINI_API_KEY=your_key_here
GEMINI_KEY_2=your_second_key_here
# Пул ключей Gemini одной строкой через запятую (объединяется с GEMINI_API_KEY*):
GEMINI_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro   # на 503 (перегрузка), см. Фазу 5

GROQ_API_KEY=your_key_here
GROQ_KEY_2=your_second_key_here

XAI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# === VOICE ===
ELEVENLABS_API_KEY=your_key_here

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here       # ОБЯЗАТЕЛЬНО — без него task-бот не стартует
TOPIC_ID=your_topic_id_here
TASKS_TOPIC_ID=your_tasks_topic_id_here  # топик, где принимаются задачи Claude Code
# ОБЯЗАТЕЛЬНО — единственный владелец, кому разрешён бот и постановка задач (RCE!).
OWNER_USER_ID=your_user_id_here

# === LOCAL SERVICES ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === STORAGE ===
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/sqlite/jarvis.db

# === PORTS ===
HUD_PORT=3000
API_PORT=7734
MCP_PORT=7735

# === SSH EXECUTOR (tg-media-analyzer) ===
SSH_HOST=your_tailscale_or_local_ip
SSH_USER=your_username
SSH_KEY=~/.ssh/jarvis_bot
SSH_HOME=~
TASKS_DIR=~/Projects/jarvis/tasks
DATA_DIR=~/Projects/jarvis/data
EXECUTOR=ssh                  # ssh (рабочий) | local (SQLite-очередь, отдельным шагом)
BATCH_TIMEOUT=8
MAX_IMAGE_SIZE=4194304        # 4 MB

# === ANIME API ===
ANIME_API_TOKEN=generate_with_python_secrets

# === ENV ===
NODE_ENV=development
