# === AI PROVIDERS (поддержка множественных ключей: _KEY_1, _KEY_2, ...) ===
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_KEY_2=your_second_key_here

GEMINI_API_KEY=your_key_here
GEMINI_KEY_2=your_second_key_here

GROQ_API_KEY=your_key_here
GROQ_KEY_2=your_second_key_here

XAI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# === VOICE ===
ELEVENLABS_API_KEY=your_key_here

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here       # ОБЯЗАТЕЛЬНО — без него task-бот не стартует
TOPIC_ID=your_topic_id_here
TASKS_TOPIC_ID=your_tasks_topic_id_here  # топик, где принимаются задачи Claude Code
# ОБЯЗАТЕЛЬНО — единственный владелец, кому разрешён бот и постановка задач (RCE!).
OWNER_USER_ID=your_user_id_here

# === LOCAL SERVICES ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === STORAGE ===
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/sqlite/jarvis.db

# === PORTS ===
HUD_PORT=3000
API_PORT=7734
MCP_PORT=7735

# === ENV ===
NODE_ENV=development
