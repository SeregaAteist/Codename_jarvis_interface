# Токен бота от @BotFather
TELEGRAM_TOKEN=7xxxxxxxxxx:AAF...

# ID супергруппы (отрицательное число, например -1001234567890)
TELEGRAM_CHAT_ID=-1001234567890

# ID темы "📥 Медиа" — правой кнопкой по теме → Copy Link, число в конце ссылки
TOPIC_ID=123

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Путь к скомпилированному бинарю whisper.cpp (обычно называется main или whisper-cli)
WHISPER_BIN=/Users/seregaateist/jarvis/voice/main

# Путь к модели whisper (base = 148 MB, лучший баланс скорость/качество на M2)
WHISPER_MODEL=/Users/seregaateist/jarvis/voice/models/ggml-base.bin
